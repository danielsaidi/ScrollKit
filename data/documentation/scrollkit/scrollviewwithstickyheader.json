ew scrolls. The function receives the scroll"},{"type":"text","text":" "},{"type":"text","text":"view offset and a header visible ratio, which indicates how"},{"type":"text","text":" "},{"type":"text","text":"much of the header that is visible below the navigation bar."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This view enforces "},{"type":"codeVoice","code":".navigationBarTitleDisplayMode(.inline)"},{"type":"text","text":" "},{"type":"text","text":"since a large title doesn’t work with a sticky header."}]},{"style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"toolbarBackground(.hidden)"},{"type":"text","text":" is applied on iOS"},{"type":"text","text":" "},{"type":"text","text":"16 and later, to make the navigation bar transparent. It is"},{"type":"text","text":" "},{"type":"text","text":"not applied on iOS 15 and earlier. This means that you must"},{"type":"text","text":" "},{"type":"text","text":"use another way to make the navigation bar transparent when"},{"type":"text","text":" "},{"type":"text","text":"you target older iOS versions. One way is to use appearance"},{"type":"text","text":" "},{"type":"text","text":"proxies if you can fall down to UIKit."}]}],"type":"aside","name":"Important"}]}],"references":{"doc://ScrollKit/documentation/ScrollKit/ScrollViewWithStickyHeader":{"role":"symbol","title":"ScrollViewWithStickyHeader","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ScrollViewWithStickyHeader"}],"abstract":[{"type":"text","text":"This scroll view lets you provide a scroll view header that"},{"type":"text","text":" "},{"type":"text","text":"sticks to the top when the view scrolls."}],"identifier":"doc:\/\/ScrollKit\/documentation\/ScrollKit\/ScrollViewWithStickyHeader","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"ScrollViewWithStickyHeader"}],"url":"\/documentation\/scrollki