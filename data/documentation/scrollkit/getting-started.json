{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"ScrollKit has a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ScrollKit\/documentation\/ScrollKit\/ScrollViewWithOffset"},{"type":"text","text":" that provides you with the scroll view offset as it’s scrolled, a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ScrollKit\/documentation\/ScrollKit\/ScrollViewWithStickyHeader"},{"type":"text","text":" that pins the header view to the top as it is scrolled below the navigation bar and a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ScrollKit\/documentation\/ScrollKit\/ScrollViewHeader"},{"type":"text","text":" that automatically stretches out when the scroll view is pulled down."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The scroll views are designed to be easy to use, and basically just add more properties to the standard SwiftUI "},{"type":"codeVoice","code":"ScrollView"},{"type":"text","text":". They can be used on all Apple platforms, including iOS, macOS, tvOS and watchOS."}]},{"anchor":"How-to-track-the-scroll-offset","level":2,"type":"heading","text":"How to track the scroll offset"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To track the scroll offset, you can use a "},{"type":"codeVoice","code":"ScrollViewWithOffset"},{"type":"text","text":" instead of a regular "},{"type":"codeVoice","code":"ScrollView"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["struct MyView: View {","","    @State","    private var offset = CGPoint.zero","    ","    func handleOffset(_ scrollOffset: CGPoint) {","        self.offset = scrollOffset","    }","","    var body: some View {","        ScrollViewWithOffset(onScroll: handleOffset) {","            \/\/ Add your scroll view content here as regular","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can then use this offset in any way you like, to for instance fade in a navigation bar title."}]},{"anchor":"How-to-set-up-a-scroll-view-with-a-sticky-header","level":2,"type":"heading","text":"How to set up a scroll view with a sticky header"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To create a scroll view with a sticky header, just create a "},{"type":"codeVoice","code":"ScrollViewWithStickyHeader"},{"type":"text","text":" and provide it with a header view and header height:"}]},{"type":"codeListing","syntax":"swift","code":["struct MyView: View {","","    @State","    private var offset = CGPoint.zero","    ","    @State","    private var visibleRatio = CGFloat.zero","    ","    func handleOffset(_ scrollOffset: CGPoint, visibleHeaderRatio: CGFloat) {","        self.offset = scrollOffset","        self.visible = visibleHeaderRatio","    }","    ","    func header() -> some View {","        ZStack(alignment: .bottomLeading) {","            Color.blue","            Color.yellow.opacity(visibleRatio)  \/\/ Fades in","        }","    }","","    var body: some View {","        ScrollViewWithStickyHeader(","            header: header,","            headerHeight: 250,","            onScroll: handleOffset","        ) {","            \/\/ Add your scroll view content here as regular","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The header visible ratio is based on the header height and scroll view offset and lets you adjust your content as the header is scrolled under the navigation bar."}]},{"anchor":"More-views","level":2,"type":"heading","text":"More views"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Other than these views, you can use the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ScrollKit\/documentation\/ScrollKit\/ScrollViewHeader"},{"type":"text","text":" in a regular "},{"type":"codeVoice","code":"ScrollView"},{"type":"text","text":" to create a header that stretches out when the scroll view is pulled down, but scrolls away together with the rest of the scroll view content."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The library also has a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ScrollKit\/documentation\/ScrollKit\/ScrollViewHeaderGradient"},{"type":"text","text":", which is just a convenience if you want to add a gradient to the header view. This is sometimes needed when you use a background image where light or dark parts of the image can make the text content hard to read."}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"variants":[{"paths":["\/documentation\/scrollkit\/getting-started"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/ScrollKit\/documentation\/ScrollKit\/Getting-Started","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"ScrollKit is a SwiftUI library that adds powerful scrolling features to SwiftUI, such as offset tracking and sticky scroll header views."}],"kind":"article","metadata":{"roleHeading":"Article","title":"Getting Started","role":"article","modules":[{"name":"ScrollKit"}]},"hierarchy":{"paths":[["doc:\/\/ScrollKit\/documentation\/ScrollKit"]]},"references":{"doc://ScrollKit/documentation/ScrollKit/ScrollViewHeaderGradient":{"role":"symbol","title":"ScrollViewHeaderGradient","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ScrollViewHeaderGradient"}],"abstract":[{"type":"text","text":"This view can be used as a scroll view header overlay, when"},{"type":"text","text":" "},{"type":"text","text":"the background may cause the content to be hard to overview."}],"identifier":"doc:\/\/ScrollKit\/documentation\/ScrollKit\/ScrollViewHeaderGradient","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"ScrollViewHeaderGradient"}],"url":"\/documentation\/scrollkit\/scrollviewheadergradient"},"doc://ScrollKit/documentation/ScrollKit":{"role":"collection","title":"ScrollKit","abstract":[{"type":"text","text":"ScrollKit is a SwiftUI library that adds powerful scrolling features to SwiftUI, such as offset tracking and sticky scroll header views."}],"identifier":"doc:\/\/ScrollKit\/documentation\/ScrollKit","kind":"symbol","type":"topic","url":"\/documentation\/scrollkit"},"doc://ScrollKit/documentation/ScrollKit/ScrollViewHeader":{"role":"symbol","title":"ScrollViewHeader","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ScrollViewHeader"}],"abstract":[{"type":"text","text":"This view can be used as a scroll view header and stretches"},{"type":"text","text":" "},{"type":"text","text":"out if the scroll view is pulled down."}],"identifier":"doc:\/\/ScrollKit\/documentation\/ScrollKit\/ScrollViewHeader","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"ScrollViewHeader"}],"url":"\/documentation\/scrollkit\/scrollviewheader"},"doc://ScrollKit/documentation/ScrollKit/ScrollViewWithStickyHeader":{"role":"symbol","title":"ScrollViewWithStickyHeader","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ScrollViewWithStickyHeader"}],"abstract":[{"type":"text","text":"This scroll view lets you provide a header view that sticks"},{"type":"text","text":" "},{"type":"text","text":"to the top when the scroll view scrolls."}],"identifier":"doc:\/\/ScrollKit\/documentation\/ScrollKit\/ScrollViewWithStickyHeader","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"ScrollViewWithStickyHeader"}],"url":"\/documentation\/scrollkit\/scrollviewwithstickyheader"},"doc://ScrollKit/documentation/ScrollKit/ScrollViewWithOffset":{"role":"symbol","title":"ScrollViewWithOffset","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ScrollViewWithOffset"}],"abstract":[{"type":"text","text":"This scroll view wraps a native "},{"type":"codeVoice","code":"ScrollView"},{"type":"text","text":" and tracks its"},{"type":"text","text":" "},{"type":"text","text":"scroll offset as it scrolls."}],"identifier":"doc:\/\/ScrollKit\/documentation\/ScrollKit\/ScrollViewWithOffset","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"ScrollViewWithOffset"}],"url":"\/documentation\/scrollkit\/scrollviewwithoffset"}}}